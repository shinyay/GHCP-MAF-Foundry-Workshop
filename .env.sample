# 0-3 で取得した Foundry プロジェクトの endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# 0-4 でデプロイしたモデルの "Deployment name"
# (Agent Framework 1.0 公式 Quickstart の正規環境変数名)
FOUNDRY_MODEL=gpt-4.1-mini

# Lab 3 で azd ai agent init / deploy したエージェントの名前とバージョン (Lab 4 / Lab 5 で使う)
HOSTED_AGENT_NAME=ms-updates-agent
HOSTED_AGENT_VERSION=1
